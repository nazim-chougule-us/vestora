# Vestora Backend Environment Variables

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=vestora

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-random-secret-string
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# us.inc AI API
USINC_API_KEY=your-usinc-api-key
USINC_BASE_URL=https://api.us.inc/usf/v1
USINC_LLM_MODEL=usf-mini
USINC_IMAGE_MODEL=usf-mini-image

# Weather (Google Maps Weather API)
GCP_API_KEY=your-gcp-api-key

# AWS S3 Image Storage (private bucket — signed URLs)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=your-bucket-name
S3_SIGNED_URL_EXPIRY=3600

# Environment ("development" or "production")
ENVIRONMENT=development

# CORS
FRONTEND_URL=http://localhost:3000
